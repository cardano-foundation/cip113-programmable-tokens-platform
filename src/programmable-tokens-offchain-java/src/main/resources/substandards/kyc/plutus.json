    "kyc_transfer/KycProof": {
      "title": "KycProof",
      "description": "A KYC proof attesting that a user has been verified by a trusted entity.\n The trusted entity's vkey is looked up from the global state UTxO datum.",
      "anyOf": [
        {
          "title": "KycProof",
          "dataType": "constructor",
          "index": 0,
          "fields": [
            {
              "title": "global_state_idx",
              "description": "Index of the global state UTxO in the transaction's reference inputs",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "vkey_idx",
              "description": "Index of the trusted entity's vkey in the global state datum list",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "payload",
              "description": "37-byte payload: user_pkh(28) || role(1) || valid_until(8)",
              "$ref": "#/definitions/ByteArray"
            },
            {
              "title": "signature",
              "description": "64-byte Ed25519 signature over `payload`, produced by the trusted entity",
              "$ref": "#/definitions/ByteArray"
            }
          ]
        }
      ]
    },
    "types/global_state/GlobalStateDatum": {
      "title": "GlobalStateDatum",
      "description": "Types for the KYC global state UTxO.\n\n The global state UTxO holds mutable per-token state including the Trusted\n Entity List (TEL), transfer pause flag, mintable amount cap, and arbitrary\n security/compliance metadata.\n Datum stored in the global state UTxO.",
      "anyOf": [
        {
          "title": "GlobalStateDatum",
          "dataType": "constructor",
          "index": 0,
          "fields": [
            {
              "title": "transfers_paused",
              "description": "If true, no transfer can be executed",
              "$ref": "#/definitions/Bool"
            },
            {
              "title": "mintable_amount",
              "description": "Goes to zero when new tokens are minted, increases when tokens are burnt",
              "$ref": "#/definitions/Int"
            },
            {
              "title": "trusted_entities",
              "description": "Ed25519 verification keys (32 bytes each) of entities authorized to sign\n KYC attestations for this token",
              "$ref": "#/definitions/List<ByteArray>"
            },
            {
              "title": "security_info",
              "description": "Regulation compliancy info, not directly used in the contracts",
              "$ref": "#/definitions/Data"
            }
          ]
        }
      ]
    },
